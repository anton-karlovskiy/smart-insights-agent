# Secrets
.env
.env.*
!.env.example

# Pipeline output. The committed real run is out/insights.json
# so reviewers without an API key can run `evaluate` against it; other ad-hoc
# output files (e.g. single-row --output runs) stay out of the diff.
out/*
!out/insights.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
build/
dist/
*.egg-info/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
